# Copy this file to .env and fill in real values. Never commit .env itself.

# RPC endpoints for BSC testnet/mainnet
BSC_TESTNET_RPC_URL=
BSC_MAINNET_RPC_URL=

# Deployer wallet private key - fund this wallet with only what deployment
# and testing needs. Never commit this value, never paste it anywhere
# outside your own local environment or CI secret store.
DEPLOYER_PRIVATE_KEY=
