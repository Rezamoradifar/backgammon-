# Copy to .env for local development. Never commit .env itself.

DATABASE_URL="postgresql://backgammon:backgammon_dev_password@localhost:5432/backgammon_dev"

# Chain
CHAIN_ID=97
RPC_URL=
GAME_MANAGER_ADDRESS=
PLAYER_REGISTRY_ADDRESS=

# Only set while GameManager's active randomness provider is
# MockRandomnessProvider (testnet/dev only - never point this at a mainnet
# deployment). Without these two, RandomnessRequested events are ignored and
# startGame() will never progress past AWAITING randomness, since nothing
# else ever calls fulfill(). See gameManagerIndexer.ts's onRandomnessRequested.
MOCK_RANDOMNESS_PROVIDER_ADDRESS=
MOCK_RANDOMNESS_RELAYER_KEY=

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d

PORT=4000
